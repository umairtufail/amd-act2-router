# Copy to .env for local work. Never commit a real key or bake this file into
# the submission image.
FIREWORKS_API_KEY=your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Use only IDs returned by the hackathon ALLOWED_MODELS command. These are
# independent measured arms; tier names do not guarantee quality or token cost.
MODEL_TIER0=accounts/fireworks/models/gpt-oss-120b
MODEL_TIER1=accounts/fireworks/models/kimi-k2p6
MODEL_TIER2=accounts/fireworks/models/glm-5p2
MODEL_TIER3=accounts/fireworks/models/deepseek-v4-pro
MODEL_JUDGE=accounts/fireworks/models/glm-5p2

# Optional compliance guard. JSON and comma-separated forms are accepted.
# ALLOWED_MODELS=["accounts/fireworks/models/gpt-oss-120b","accounts/fireworks/models/kimi-k2p6","accounts/fireworks/models/glm-5p2","accounts/fireworks/models/deepseek-v4-pro"]

# Evidenced submission policy: tier0 first, deterministic verification, and at
# most one Fireworks fallback. The default fallback order tries tier3 first.
ROUTER_MODE=verified_tier0
ANSWER_FALLBACKS=1
ANSWER_FALLBACK_TIERS=tier3

# Shared serving/labeling/holdout request policy. Changing these values changes
# request_policy_sha256 and requires fresh measurements.
ANSWER_MAX_TOKENS=700
ANSWER_TEMPERATURE=0.0
# ANSWER_REASONING_EFFORT=low
# ANSWER_SYSTEM_PROMPT=Answer directly and concisely while remaining complete.

# Runtime concurrency. Results are still written in input order.
ANSWER_WORKERS=4

# Binary thresholds apply only to explicit offline/source analysis. The binary
# router and its checkpoint are not packaged in the submission image.
# BINARY_ROUTER_TAU=0.8
# NER_BINARY_TAU=0.9

# Optional local judge/demo development. Never set DEV_LOCAL_ANSWERS in the
# submission environment.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.2
# JUDGE_BACKEND=auto
