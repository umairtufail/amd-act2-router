# Copy to .env and fill in. NEVER commit real keys.
FIREWORKS_API_KEY=your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Model IDs MUST come from the hackathon's ALLOWED_MODELS list
# (MiniMax / Kimi K series per the participant FAQ).
# The values below are placeholders — replace them.
MODEL_TIER0=accounts/fireworks/models/REPLACE-cheapest
MODEL_TIER1=accounts/fireworks/models/REPLACE-mid-low
MODEL_TIER2=accounts/fireworks/models/REPLACE-mid-high
MODEL_TIER3=accounts/fireworks/models/REPLACE-strongest

# Judge used only during dataset labeling (grading answers).
MODEL_JUDGE=accounts/fireworks/models/REPLACE-judge

# Routing mode for the agent: multitier | prompt_baseline | always_tier0 | always_tier3
ROUTER_MODE=multitier
